# ==========================================
# Kafka
# ==========================================
KAFKA_IMAGE=apache/kafka:4.3.1
KAFKA_CLUSTER_ID=replace_with_generated_cluster_id

# ==========================================
# Kafka topic
# ==========================================
KAFKA_TOPIC=retail-payment-events
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_RETENTION_MS=604800000

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_IMAGE=postgres:17.10
POSTGRES_USER=lakehouse
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=lakehouse_metadata

# ==========================================
# MinIO Community source build
# Local educational/development environment only
# ==========================================
MINIO_RELEASE=RELEASE.2025-10-15T17-29-55Z
MINIO_IMAGE=lakehouse-minio:RELEASE.2025-10-15T17-29-55Z

MINIO_ROOT_USER=lakehouse_admin
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=lakehouse
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Host-side Python application endpoint
MINIO_ENDPOINT_URL=http://localhost:9000

# Day 3 temporary Bronze layout.
# processing_date partitioning will be added on Week 2 Day 5.
BRONZE_PREFIX=bronze/events/_unpartitioned

# Spark
SPARK_IMAGE=apache/spark:3.5.8
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_WEBUI_PORT=8081

# Apache Airflow — local skeleton
AIRFLOW_IMAGE=apache/airflow:3.2.2-python3.11
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_strong_password
AIRFLOW_WEB_PORT=8088
AIRFLOW_UID=50000
AIRFLOW_ADMIN_FIRSTNAME=Lakehouse
AIRFLOW_ADMIN_LASTNAME=Admin

# Streamlit
STREAMLIT_IMAGE=python:3.11.15-slim-bookworm
STREAMLIT_PORT=8501
