# ==========================================
# Kafka
# ==========================================
KAFKA_IMAGE=apache/kafka:4.3.1
KAFKA_CLUSTER_ID=replace_with_generated_cluster_id

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_IMAGE=postgres:17.10
POSTGRES_USER=lakehouse
POSTGRES_PASSWORD=replace_with_strong_local_password
POSTGRES_DB=lakehouse_metadata

# ==========================================
# MinIO AIStor Free
# Pin the image by digest after first pull.
# ==========================================
MINIO_RELEASE=RELEASE.2025-10-15T17-29-55Z
MINIO_IMAGE=lakehouse-minio:RELEASE.2025-10-15T17-29-55Z

MINIO_ROOT_USER=lakehouse_admin
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=lakehouse
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001